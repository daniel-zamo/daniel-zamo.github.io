# ==========================================
# 1. Docusaurus & Node Core
# ==========================================
node_modules/
.docusaurus/
.cache-loader/
build/
dist/
.temp/
.cache/

# ==========================================
# 2. Logs y Diagnósticos
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
.eslintcache

# ==========================================
# 3. Variables de Entorno y Secretos (Seguridad)
# ==========================================
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Archivos de llaves o certificados
*.pem
*.key
certs/
secrets.yaml

# ==========================================
# 4. Metadatos del Sistema y Editores
# ==========================================
.DS_Store
Thumbs.db
desktop.ini

# Editores (VSCode, JetBrains, etc)
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==========================================
# 5. Reglas Personalizadas (Legacy & Workflow)
# ==========================================
# Basado en tus archivos anteriores (v*, bkp, etc)
*.org
*.v*
*.bkp
*~
**/zz_archives
tmp/
temp/
*.tgz
*.tar
*.zip
*.exe
*.rar
**/data/
**/+/
**/external-resources
**/_projects/my_library
daniel-zamo.github.io_generate_report.sh
**/*report-spec*.md

# Scripts de automatización que no deben versionarse (según tu contexto)
scripts/ops/.secrets
*.sh.bak

# ==========================================
# 6. Otros lenguajes (Python/Venv)
# ==========================================
# Por si acaso usas scripts de procesamiento de datos en Python
venv/
.venv/
__pycache__/
*.py[cod]

# ==========================================
# 7. Excepciones (Archivos que SÍ queremos)
# ==========================================
# Aunque ignoremos carpetas con guion bajo por estándar, 
# Docusaurus necesita estos para la estructura:
!**/_category_.json
!**/_category_.yml
!**/_category_.yaml

# =========================================
# 8. Ansible
# =========================================
*.retry
*.log
.ansible/
# Si usas Vault con archivo de password
.ansible_vault_pass
# SSH sockets de ControlPersist
ansible-ssh-*
inventory
hosts.ini
inventory.ini
